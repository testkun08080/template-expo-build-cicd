# このファイルをコピーして .env を作成し、実際の値を入れてください（.env はコミットしない）
#
#   cp fastlane/.env.example fastlane/.env
#
# キーの詳細・CI への登録方法は docs/secrets-and-env.md を参照。
# Fastlane Match の手順は docs/05-github-actions-fastlane.md を参照。

# --- Apple（ビルド・TestFlight 提出） ---
APPLE_ID=
APPLE_TEAM_ID=
APP_IDENTIFIER=
# TestFlight 提出時のみ（ローカルは .p8 ファイルパスを推奨）
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_KEY_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=
# CI (GHA) では base64 化した中身を APP_STORE_CONNECT_API_KEY_P8 に設定
APP_STORE_CONNECT_API_KEY_P8=

# --- fastlane match（証明書管理用の別 Git リポジトリ） ---
# 初回セットアップ（管理者）: docs/05-github-actions-fastlane.md
# 参加者: 管理者から共有された値をコピー
MATCH_GIT_URL=
MATCH_PASSWORD=
MATCH_TYPE=appstore

# --- EAS（fastlane では不要。EAS ビルド用） ---
EXPO_TOKEN=
ASC_APP_ID=

# --- Android（fastlane android build 時） ---
ANDROID_KEYSTORE_BASE64=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
