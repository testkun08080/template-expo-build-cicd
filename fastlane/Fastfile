# frozen_string_literal: true

default_platform(:ios)

def project_root
  File.expand_path("..", __dir__)
end

def ios_scheme_name
  ENV["SCHEME_NAME"] || "templateexpobuild"
end

def ios_workspace_path
  File.join(project_root, "ios", "#{ios_scheme_name}.xcworkspace")
end

def ios_xcodeproj_path
  File.join(project_root, "ios", "#{ios_scheme_name}.xcodeproj")
end

def ios_app_identifier
  ENV["APP_IDENTIFIER"] || "com.testkun08080.template-expo-build"
end

def match_provisioning_profile_name
  profile_type = {
    "development" => "Development",
    "appstore" => "AppStore",
    "adhoc" => "AdHoc",
    "enterprise" => "InHouse"
  }.fetch(ENV["MATCH_TYPE"] || "appstore", "AppStore")

  "match #{profile_type} #{ios_app_identifier}"
end

def configure_ios_code_signing!
  # expo prebuild regenerates ios/ with automatic signing; apply match profiles before gym.
  update_code_signing_settings(
    use_automatic_signing: false,
    path: ios_xcodeproj_path,
    team_id: ENV["APPLE_TEAM_ID"],
    targets: [ios_scheme_name],
    build_configurations: ["Release"],
    code_sign_identity: "Apple Distribution",
    profile_name: match_provisioning_profile_name
  )
end

def api_key_configured?
  key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
  issuer_id = ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"] || ENV["APP_STORE_CONNECT_API_ISSUER_ID"]
  p8 = ENV["APP_STORE_CONNECT_API_KEY_P8"]
  path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
  !key_id.to_s.empty? && !issuer_id.to_s.empty? && (!p8.to_s.empty? || !path.to_s.empty?)
end

def bump_ios_build_number!
  return unless File.exist?(ios_xcodeproj_path)

  build_number = ENV["BUILD_NUMBER"]
  if build_number.nil? || build_number.empty?
    if api_key_configured?
      latest = latest_testflight_build_number(
        api_key: fetch_app_store_connect_api_key,
        app_identifier: ios_app_identifier
      )
      build_number = (latest + 1).to_s
      UI.message("Auto-incremented build number from TestFlight: #{build_number}")
    else
      UI.important("BUILD_NUMBER not set and App Store Connect API key unavailable; using build number from app.json")
      return
    end
  end

  increment_build_number(
    xcodeproj: ios_xcodeproj_path,
    build_number: build_number
  )
end

def ios_ipa_path
  ENV["IPA_PATH"] || Actions.lane_context[SharedValues::IPA_OUTPUT_PATH] || File.join(project_root, "build", "#{ios_scheme_name}.ipa")
end

def upload_ipa_to_testflight!
  ipa_path = ios_ipa_path
  UI.user_error!("IPA not found: #{ipa_path}") unless File.exist?(ipa_path)

  upload_to_testflight(
    ipa: ipa_path,
    api_key: fetch_app_store_connect_api_key,
    skip_waiting_for_build_processing: true
  )
end

def fetch_app_store_connect_api_key
  key_id = ENV["APP_STORE_CONNECT_API_KEY_ID"]
  issuer_id = ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"] || ENV["APP_STORE_CONNECT_API_ISSUER_ID"]

  if key_id.nil? || key_id.empty? || issuer_id.nil? || issuer_id.empty?
    UI.user_error!("APP_STORE_CONNECT_API_KEY_ID and APP_STORE_CONNECT_API_KEY_ISSUER_ID are required for TestFlight upload")
  end

  key_content = ENV["APP_STORE_CONNECT_API_KEY_P8"]
  unless key_content.nil? || key_content.empty?
    decoded_key = begin
      Base64.decode64(key_content)
    rescue StandardError
      key_content
    end

    return app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: decoded_key,
      is_key_content_base64: false
    )
  end

  key_path = ENV["APP_STORE_CONNECT_API_KEY_PATH"]
  unless key_path.nil? || key_path.empty?
    resolved_path = key_path.start_with?("/") ? key_path : File.expand_path(key_path, __dir__)
    UI.user_error!("APP_STORE_CONNECT_API_KEY_PATH not found: #{resolved_path}") unless File.exist?(resolved_path)

    return app_store_connect_api_key(
      key_id: key_id,
      issuer_id: issuer_id,
      key_filepath: resolved_path
    )
  end

  UI.user_error!("APP_STORE_CONNECT_API_KEY_P8 (CI) or APP_STORE_CONNECT_API_KEY_PATH (local) is required for TestFlight upload")
end

platform :ios do
  desc "Sync certificates from match (readonly)"
  lane :certificates do
    setup_ci if ENV["CI"]
    match(
      type: ENV["MATCH_TYPE"] || "appstore",
      readonly: true
    )
  end

  desc "Create or renew certificates in match (admin only)"
  lane :certificates_renew do
    setup_ci if ENV["CI"]
    match(
      type: ENV["MATCH_TYPE"] || "appstore",
      readonly: false
    )
  end

  desc "Prebuild, sign, and create an App Store .ipa"
  lane :build do
    Dir.chdir(project_root) do
      sh("npx expo prebuild --platform ios --no-install")
      Dir.chdir("ios") do
        # bundle exec fastlane sets BUNDLE_GEMFILE; pod must not inherit it.
        Bundler.with_unbundled_env do
          sh("pod install")
        end
      end
    end

    bump_ios_build_number!

    # Temporary keychain for non-interactive codesigning on CI (avoids UI ACL prompts).
    setup_ci if ENV["CI"]

    match(
      type: ENV["MATCH_TYPE"] || "appstore",
      readonly: true
    )

    configure_ios_code_signing!

    gym(
      workspace: ios_workspace_path,
      scheme: ios_scheme_name,
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        provisioningProfiles: {
          ios_app_identifier => match_provisioning_profile_name
        }
      },
      output_directory: File.join(project_root, "build"),
      output_name: "#{ios_scheme_name}.ipa",
      clean: true
    )
  end

  desc "Upload an existing .ipa to TestFlight"
  lane :upload do
    upload_ipa_to_testflight!
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    build
    upload_ipa_to_testflight!
  end
end

platform :android do
  desc "Prebuild, restore keystore, and create a release app bundle"
  lane :build do
    keystore_path = File.join(project_root, "android", "app", "release.keystore")

    if ENV["ANDROID_KEYSTORE_BASE64"]
      FileUtils.mkdir_p(File.dirname(keystore_path))
      File.binwrite(
        keystore_path,
        Base64.decode64(ENV["ANDROID_KEYSTORE_BASE64"])
      )
    end

    Dir.chdir(project_root) do
      sh("npx expo prebuild --platform android --no-install")
      sh(
        "cd android && ./gradlew bundleRelease " \
        "-Pandroid.injected.signing.store.file=#{keystore_path} " \
        "-Pandroid.injected.signing.store.password=#{ENV['ANDROID_KEYSTORE_PASSWORD']} " \
        "-Pandroid.injected.signing.key.alias=#{ENV['ANDROID_KEY_ALIAS']} " \
        "-Pandroid.injected.signing.key.password=#{ENV['ANDROID_KEY_PASSWORD']}"
      )
    end
  end
end
