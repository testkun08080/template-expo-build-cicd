# frozen_string_literal: true

default_platform(:ios)

def project_root
  File.expand_path("..", __dir__)
end

def ios_scheme_name
  ENV["SCHEME_NAME"] || "templateexpobuild"
end

def ios_workspace_path
  File.join(project_root, "ios", "#{ios_scheme_name}.xcworkspace")
end

def fetch_app_store_connect_api_key
  key_content = ENV["APP_STORE_CONNECT_API_KEY_P8"]
  if key_content.nil? || key_content.empty?
    UI.user_error!("APP_STORE_CONNECT_API_KEY_P8 is required for TestFlight upload")
  end

  decoded_key = begin
    Base64.decode64(key_content)
  rescue StandardError
    key_content
  end

  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
    key_content: decoded_key,
    is_key_content_base64: false
  )
end

platform :ios do
  desc "Sync certificates from match (readonly)"
  lane :certificates do
    match(
      type: ENV["MATCH_TYPE"] || "appstore",
      readonly: true
    )
  end

  desc "Create or renew certificates in match (admin only)"
  lane :certificates_renew do
    match(
      type: ENV["MATCH_TYPE"] || "appstore",
      readonly: false
    )
  end

  desc "Prebuild, sign, and create an App Store .ipa"
  lane :build do
    Dir.chdir(project_root) do
      sh("npx expo prebuild --platform ios --no-install")
      Dir.chdir("ios") do
        sh("pod install")
      end
    end

    match(
      type: ENV["MATCH_TYPE"] || "appstore",
      readonly: true
    )

    gym(
      workspace: ios_workspace_path,
      scheme: ios_scheme_name,
      configuration: "Release",
      export_method: "app-store",
      output_directory: File.join(project_root, "build"),
      output_name: "#{ios_scheme_name}.ipa",
      clean: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    build

    upload_to_testflight(
      api_key: fetch_app_store_connect_api_key,
      skip_waiting_for_build_processing: true
    )
  end
end

platform :android do
  desc "Prebuild, restore keystore, and create a release app bundle"
  lane :build do
    keystore_path = File.join(project_root, "android", "app", "release.keystore")

    if ENV["ANDROID_KEYSTORE_BASE64"]
      FileUtils.mkdir_p(File.dirname(keystore_path))
      File.binwrite(
        keystore_path,
        Base64.decode64(ENV["ANDROID_KEYSTORE_BASE64"])
      )
    end

    Dir.chdir(project_root) do
      sh("npx expo prebuild --platform android --no-install")
      sh(
        "cd android && ./gradlew bundleRelease " \
        "-Pandroid.injected.signing.store.file=#{keystore_path} " \
        "-Pandroid.injected.signing.store.password=#{ENV['ANDROID_KEYSTORE_PASSWORD']} " \
        "-Pandroid.injected.signing.key.alias=#{ENV['ANDROID_KEY_ALIAS']} " \
        "-Pandroid.injected.signing.key.password=#{ENV['ANDROID_KEY_PASSWORD']}"
      )
    end
  end
end
