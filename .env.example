# このファイルをコピーして .env.local を作成し、実際の値を入れてください（.env.local はコミットしない）
# 各ビルド方法で使うキーの詳細は docs/secrets-and-env.md を参照

# --- EAS ---
EXPO_TOKEN=

# --- Apple ---
APPLE_ID=
ASC_APP_ID=
APPLE_TEAM_ID=
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_PATH=

# --- fastlane match（証明書管理用の別Gitリポジトリ） ---
MATCH_GIT_URL=
MATCH_PASSWORD=
MATCH_TYPE=appstore

# --- Android ---
ANDROID_KEYSTORE_BASE64=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
